# Minimal backtest research profile focused on signal parity.
# Use this as a clean starting point instead of the large live env.

EXCHANGE_PROVIDER=okx
ALERT_ONLY_MODE=1
OKX_DRY_RUN=1

OKX_INST_IDS=BTC-USDT-SWAP
OKX_HTF_BAR=4H
OKX_LOC_BAR=1H
OKX_LTF_BAR=15m
OKX_CANDLE_LIMIT=4000
OKX_HISTORY_CACHE_ENABLED=1
OKX_BACKTEST_LIVE_WINDOW_SIGNALS=1

# Keep backtest research intentionally narrow.
STRAT_ALLOWED_VARIANTS=pa_oral_baseline_v1
STRAT_VARIANT=pa_oral_baseline_v1
STRAT_EXEC_MAX_LEVEL=2
STRAT_SIGNAL_EXIT_ENABLED=1
STRAT_SPLIT_TP_ON_ENTRY=0

# Keep profile/vote config empty unless you are deliberately testing profile mixes.
# STRAT_PROFILE_INST_GROUPS=
# STRAT_PROFILE_MAP=
# STRAT_PROFILE_VOTE_INST_GROUPS=
# STRAT_PROFILE_VOTE_MAP=
# STRAT_PROFILE_VOTE_MODE=majority
# STRAT_PROFILE_VOTE_MIN_AGREE=1

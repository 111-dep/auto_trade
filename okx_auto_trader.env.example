# 复制为 okx_auto_trader.env 后再填写真实参数。
# 本文件是模板，不含真实密钥。

# ==================== OKX 认证（敏感） ====================
# API Key（必填）
OKX_API_KEY=
# Secret Key（必填）
OKX_SECRET_KEY=
# API Passphrase（必填）
OKX_PASSPHRASE=

# ==================== 连接与运行模式 ====================
# OKX 接口地址，默认官网
OKX_BASE_URL=https://www.okx.com
# 是否模拟盘：1=模拟盘，0=实盘
OKX_PAPER=0
# 是否仅打印不下单：1=不真实下单，0=真实下单
OKX_DRY_RUN=1
# 请求头 User-Agent（如需用 bash source 本文件，建议保持引号）
OKX_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
# 日志级别：DEBUG/INFO/WARN/ERROR（建议默认 INFO）
LOG_LEVEL=INFO
# 心跳汇总日志间隔（秒，最小30；建议300）
LOG_HEARTBEAT_SECONDS=300
# 单实例锁：1=开启（推荐），0=关闭
OKX_SINGLE_INSTANCE_LOCK=1
# 单实例锁文件路径（留空则用 OKX_STATE_FILE + ".lock"）
OKX_INSTANCE_LOCK_FILE=

# ==================== 提醒模式开关 ====================
# 仅提醒模式：1=只提醒不交易，0=允许自动交易
ALERT_ONLY_MODE=1
# 是否启用邮件提醒：1=启用，0=关闭
ALERT_EMAIL_ENABLED=0

# ==================== 邮件提醒（SMTP） ====================
# SMTP 服务器地址（如 qq 邮箱 smtp.qq.com）
ALERT_SMTP_HOST=
# SMTP 端口（SSL 常用 465）
ALERT_SMTP_PORT=465
# SMTP 登录用户名（通常是邮箱地址）
ALERT_SMTP_USER=
# SMTP 登录密码/授权码
ALERT_SMTP_PASS=
# 发件人显示地址（为空则回退 SMTP_USER）
ALERT_EMAIL_FROM=
# 收件人，多个用逗号分隔
ALERT_EMAIL_TO=
# 是否使用 SSL：1=是，0=否
ALERT_SMTP_USE_SSL=1
# 是否使用 STARTTLS：1=是，0=否
ALERT_SMTP_STARTTLS=0

# ==================== Telegram 提醒 ====================
# 是否启用 TG 提醒：1=启用，0=关闭
ALERT_TG_ENABLED=0
# Bot Token（来自 BotFather）
ALERT_TG_BOT_TOKEN=
# 目标 Chat ID
ALERT_TG_CHAT_ID=
# Telegram API 基础地址
ALERT_TG_API_BASE=https://api.telegram.org
# 解析模式（空=纯文本，可选 Markdown/HTML）
ALERT_TG_PARSE_MODE=
# 提醒最大等级（1严格，2中等，3宽松；发送 <= 该等级）
ALERT_MAX_LEVEL=3
# 是否允许盘中预警（未收线也提醒）：1=是，0=否
ALERT_INTRABAR_ENABLED=1
# 提醒统计保留天数
ALERT_STATS_KEEP_DAYS=14
# 连续无新开仓超时提醒阈值（小时，<=0关闭）
ALERT_NO_OPEN_HOURS=24
# 无新开仓提醒冷却（小时，避免重复刷屏；<=0 则回退为阈值）
ALERT_NO_OPEN_COOLDOWN_HOURS=24

# ==================== 本地提醒 ====================
# 终端蜂鸣：1=开启，0=关闭
ALERT_LOCAL_SOUND=1
# 本地日志文件：1=写入，0=不写入
ALERT_LOCAL_FILE=1
# 本地提醒日志路径
ALERT_LOCAL_FILE_PATH=/home/dandan/Workspace/test/okx_trade_suite/alerts.log

# ==================== 交易台账（逐笔开平仓记录） ====================
# 是否启用交易台账：1=启用，0=关闭
TRADE_JOURNAL_ENABLED=1
# 台账文件路径（CSV）
TRADE_JOURNAL_PATH=/home/dandan/Workspace/test/okx_trade_suite/trade_journal.csv

# ==================== 交易标的与K线周期 ====================
# 多币种列表（逗号分隔），脚本会循环监控/交易
OKX_INST_IDS=BTC-USDT-SWAP,ETH-USDT-SWAP,SOL-USDT-SWAP,XRP-USDT-SWAP,DOGE-USDT-SWAP,BNB-USDT-SWAP,ADA-USDT-SWAP,LINK-USDT-SWAP
# 当 OKX_INST_IDS 为空时的单币种兜底
OKX_INST_ID=XAU-USDT-SWAP
# 大周期（方向过滤）
OKX_HTF_BAR=4H
# 位置周期（回调/位置过滤）
OKX_LOC_BAR=1H
# 入场周期（触发信号）
OKX_LTF_BAR=15m
# 主循环轮询间隔（秒）
OKX_POLL_SECONDS=10
# 每次取K线条数（需覆盖指标最小需求）
OKX_CANDLE_LIMIT=300
# 历史K线本地缓存：1=启用，0=关闭（建议开启，回测会快很多）
OKX_HISTORY_CACHE_ENABLED=1
# 历史K线缓存目录
OKX_HISTORY_CACHE_DIR=/home/dandan/Workspace/test/okx_trade_suite/okx_trader/.cache/history
# 历史K线缓存有效期（秒，建议 21600=6小时）
OKX_HISTORY_CACHE_TTL_SECONDS=21600

# ==================== 交易账户模式 ====================
# 保证金模式：cross=全仓，isolated=逐仓
OKX_TD_MODE=isolated
# 持仓模式：net=净持仓，long_short=双向持仓
OKX_POS_MODE=net

# ==================== 仓位大小模式 ====================
# fixed=固定张数；margin=按保证金*杠杆算张数
OKX_SIZING_MODE=margin
# fixed 模式下的下单张数
OKX_ORDER_SIZE=1
# margin 模式下每次开仓保证金（USDT）；>0 时优先按保证金开仓
# 若希望按 STRAT_RISK_FRAC 自动反推仓位，请设为 0
OKX_MARGIN_USDT=25
# margin 模式下杠杆倍数
OKX_LEVERAGE=5
# 开仓时是否附带交易所 TP/SL：1=附带，0=不附带（默认由脚本动态管理）
OKX_ATTACH_TPSL_ON_ENTRY=0
# 附带 TP 的 R 倍数（SL 使用策略止损位）
OKX_ATTACH_TPSL_TP_R=2.5
# 触发价类型：last/index/mark
OKX_ATTACH_TPSL_TRIGGER_PX_TYPE=mark
# ==================== 复利仓位（按净值自动调整保证金） ====================
# 是否启用复利仓位：1=启用，0=关闭（建议先用 0 观察）
OKX_COMPOUND_ENABLE=0
# 复利模式：step=阶梯调整（推荐），ratio=按净值比例连续调整
OKX_COMPOUND_MODE=step
# 基准净值（USDT）：当账户净值=该值时，使用基准保证金
OKX_COMPOUND_BASE_EQUITY=1000
# 基准保证金（USDT）：通常与 OKX_MARGIN_USDT 一致
OKX_COMPOUND_BASE_MARGIN=25
# step 模式参数：净值每增加多少 USDT，保证金增加一次
OKX_COMPOUND_STEP_EQUITY=250
# step 模式参数：每个阶梯增加多少保证金（USDT）
OKX_COMPOUND_STEP_MARGIN=2
# ratio 模式参数：保证金=基准保证金*(净值/基准净值)^power
OKX_COMPOUND_RATIO_POWER=1.0
# 动态保证金上下限（USDT）
OKX_COMPOUND_MIN_MARGIN=10
OKX_COMPOUND_MAX_MARGIN=100
# 回撤保护：当净值较峰值回撤 >= 该比例时，保证金乘以该系数
OKX_COMPOUND_DD_GUARD_PCT=0.15
OKX_COMPOUND_DD_FACTOR=0.5
# 读取净值的币种（默认 USDT），以及缓存秒数（减少频繁请求）
OKX_COMPOUND_BALANCE_CCY=USDT
OKX_COMPOUND_CACHE_SECONDS=30

# ==================== 多策略档案（按币种分组参数） ====================
# 推荐写法（按策略分组）：
# STRAT_PROFILE_INST_GROUPS=BTCETH:BTC-USDT-SWAP,ETH-USDT-SWAP;ALT:SOL-USDT-SWAP,DOGE-USDT-SWAP
# 兼容旧写法（按币种映射；与分组并存时，旧写法优先）：
# STRAT_PROFILE_MAP=BTC-USDT-SWAP:BTCETH,ETH-USDT-SWAP:BTCETH
# 同币多策略投票（同账户只下一个单）：
# 推荐写法（按策略组合分组）：
# STRAT_PROFILE_VOTE_INST_GROUPS=BTCETH+ELDER:BTC-USDT-SWAP;DEFAULT+ELDERALT:SOL-USDT-SWAP,DOGE-USDT-SWAP
# 兼容旧写法（按币种映射；与分组并存时，旧写法优先）：
# STRAT_PROFILE_VOTE_MAP=BTC-USDT-SWAP:BTCETH+ELDER
# 投票模式：any / majority / unanimous（默认 majority）
# STRAT_PROFILE_VOTE_MODE=majority
# 最少同意票数（默认1；与投票模式共同生效）
# STRAT_PROFILE_VOTE_MIN_AGREE=1
# 可选：按 profile 历史表现（如2Y avgR）打分，加权决策/平票决策
# 格式：PROFILE=score，多个逗号分隔；不填则沿用纯计票逻辑
# STRAT_PROFILE_VOTE_SCORE_MAP=BTCETH=0.154,ELDER=0.091
# 可选：等级严格度加分权重（L1/L2/L3 分别加 3/2/1 倍该值），默认0=关闭
# STRAT_PROFILE_VOTE_LEVEL_WEIGHT=0.01
# 档案参数覆盖：STRAT_PROFILE_<PROFILE>_<PARAM>
# PARAM 可用与 STRAT_* 相同的后缀，例如：
# STRAT_PROFILE_BTCETH_VARIANT=btceth_v1
# STRAT_PROFILE_BTCETH_VARIANT=btceth_smc_v0
# STRAT_PROFILE_BTCETH_VARIANT=btceth_smc_v1
# STRAT_PROFILE_BTCETH_VARIANT=elder_tss_v1
# STRAT_PROFILE_BTCETH_VARIANT=r_breaker_v1
# STRAT_PROFILE_BTCETH_LTF_ATR_STOP_MULT=2.5
# STRAT_PROFILE_BTCETH_MGMT_TP1_R=1.2
# STRAT_PROFILE_BTCETH_EXEC_MAX_LEVEL=2
# STRAT_PROFILE_XAU_LEVERAGE=25

# ==================== 策略参数（4H方向 + 1H位置 + 15m触发） ====================
# 策略变体：classic / btceth_v1 / btceth_smc_v0 / btceth_smc_v1 / elder_tss_v1 / r_breaker_v1
STRAT_VARIANT=classic
# ---- 大周期方向过滤（HTF） ----
STRAT_HTF_EMA_FAST_LEN=50
STRAT_HTF_EMA_SLOW_LEN=200
STRAT_HTF_RSI_LEN=14
STRAT_HTF_RSI_LONG_MIN=52
STRAT_HTF_RSI_SHORT_MAX=48

# ---- 位置模块（LOC） ----
STRAT_LOC_LOOKBACK=120
STRAT_LOC_RECENT_BARS=8
STRAT_LOC_SR_LOOKBACK=40
STRAT_LOCATION_FIB_LOW=0.382
STRAT_LOCATION_FIB_HIGH=0.618
STRAT_LOCATION_RETEST_TOL=0.003

# ---- 入场/出场触发（LTF） ----
STRAT_LTF_BREAK_LEN=20
STRAT_LTF_EXIT_LEN=10
STRAT_LTF_EMA_LEN=20
STRAT_LTF_BB_LEN=20
STRAT_LTF_BB_MULT=2.0
STRAT_LTF_BB_WIDTH_K=1.0
STRAT_LTF_RSI_LEN=14
STRAT_LTF_RSI_LONG_MIN=50
STRAT_LTF_RSI_SHORT_MAX=50
# L2/L3 相对 L1 的 RSI 放宽幅度（越大越容易触发）
STRAT_ALERT_L2_RSI_RELAX=2
STRAT_ALERT_L3_RSI_RELAX=5
STRAT_LTF_MACD_FAST=12
STRAT_LTF_MACD_SLOW=26
STRAT_LTF_MACD_SIGNAL=9
STRAT_LTF_PULLBACK_LOOKBACK=8
STRAT_LTF_PULLBACK_TOL=0.0015
STRAT_LTF_MAX_CHASE_EMA=0.0035
STRAT_LTF_ATR_LEN=14
STRAT_LTF_ATR_STOP_MULT=1.2
STRAT_LTF_MIN_RISK_ATR_MULT=0.8
STRAT_LTF_MIN_RISK_PCT=0.001
# 实盘单笔风险比例（按账户权益）；仅在 OKX_MARGIN_USDT=0 时生效
# 仅支持百分号写法：0.5% 表示 0.5%，0% 表示关闭
STRAT_RISK_FRAC=0%
# 风险模式硬保护：单笔“预计占用保证金”上限（占权益比例）
# 仅支持百分号写法：30% 表示最多占用权益30%
STRAT_RISK_MAX_MARGIN_FRAC=30%

# ==================== 交易管理与风控 ====================
# TP1/TP2 对应 R 倍数
STRAT_MGMT_TP1_R=1.5
STRAT_MGMT_TP2_R=2.5
# TP1 平仓比例（0~1）
STRAT_MGMT_TP1_CLOSE_PCT=0.5
# TP1 命中后，剩余仓位是否在 TP2 处全部平仓：1=是，0=否
STRAT_MGMT_TP2_CLOSE_REST=1
# 盈利达到多少 R 后启用保本
STRAT_MGMT_BE_TRIGGER_R=1.0
# 保本偏移百分比
STRAT_MGMT_BE_OFFSET_PCT=0.0005
# 保本额外费用缓冲（覆盖手续费/滑点，建议 0.0005~0.0015）
STRAT_MGMT_BE_FEE_BUFFER_PCT=0.0008
# 移动止损 ATR 倍数
STRAT_MGMT_TRAIL_ATR_MULT=1.8
# 是否 TP1 后才启用移动止损：1=是，0=否
STRAT_MGMT_TRAIL_AFTER_TP1=1

# 单币种 24h 内最多开仓次数（0=不限制）
STRAT_MAX_OPEN_ENTRIES=20
# 全局（跨全部币种）24h 内最多开仓次数（0=不限制）
STRAT_MAX_OPEN_ENTRIES_GLOBAL=0
# 统计窗口小时数（与上面两项联动）
STRAT_OPEN_WINDOW_HOURS=24
# 同一币种最小开仓间隔（分钟）
STRAT_MIN_OPEN_INTERVAL_MINUTES=15
# 当日亏损熔断阈值（支持 0.03 或 3，表示 3%；0=关闭）
STRAT_DAILY_LOSS_LIMIT_PCT=0
# 当日亏损熔断基准资金（USDT，仅统计脚本订单的24h累计亏损）
STRAT_DAILY_LOSS_BASE_USDT=1000
# 当日亏损基准模式：
# current=按当前账户金额；fixed=固定用上面基准；min=取两者较小
STRAT_DAILY_LOSS_BASE_MODE=current
# 同方向止损后冷却（分钟，0=关闭）
STRAT_STOP_REENTRY_COOLDOWN_MINUTES=60
# 同方向连续止损达到该次数后触发冻结（0=关闭）
STRAT_STOP_STREAK_FREEZE_COUNT=7
# 冻结时长（小时）
STRAT_STOP_STREAK_FREEZE_HOURS=4
# 冻结期间是否仅允许 L1/L2（拦截 L3）：1=是，0=否（0时会全拦截）
STRAT_STOP_STREAK_L2_ONLY=0

# 执行最大等级（1/2/3，包含更严格等级）
STRAT_EXEC_MAX_LEVEL=3
# 这些币种放宽到 L3 执行（逗号分隔）
STRAT_EXEC_L3_INST_IDS=

# 是否允许脚本执行平仓动作（止盈/止损/反手）
STRAT_ENABLE_CLOSE=1
# 是否允许“信号失效”提前平仓（long_exit/short_exit）：1=开启，0=关闭（基准版建议0）
STRAT_SIGNAL_EXIT_ENABLED=0
# 是否允许同一根K线平仓后反手
STRAT_ALLOW_REVERSE=1
# 是否仅管理“脚本自己开的仓位”：1=是，0=否
STRAT_MANAGE_ONLY_SCRIPT_POSITIONS=1
# 当检测到同币种存在“非当前保证金模式”持仓时是否跳过该币种：
# 1=跳过（更安全，不会碰到你的全仓仓位），0=仅忽略异模式仓位并继续本模式交易
STRAT_SKIP_ON_FOREIGN_MGNMODE_POS=1
